{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "strictPropertyInitialization": false,
    "typeRoots": [
      "./node_modules/@types",
      "./src/@types"
    ],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./src",
    "paths": {
      "@configs/*": ["configs/*"],
      "@containers": ["containers"],
      "@providers/*": ["containers/providers/*"],
      "@dtos/*": ["dtos/*"],
      "@errors/*": ["errors/*"],
      "@infra/*": ["infra/*"],
      "@repositories/*": ["repositories/*"],
      "@services/*": ["services/*"]
    }
  },
  "include": [
    "src/**/*"
  ]
}
