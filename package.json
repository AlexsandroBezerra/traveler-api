{
  "name": "traveler-api",
  "version": "1.0.0",
  "private": true,
  "description": "A rest API for Traveler application",
  "license": "MIT",
  "author": "Alexsandro G Bezerra",
  "main": "dist/infra/http/server.js",
  "scripts": {
    "build": "babel src --extensions \".ts\" --out-dir dist --copy-files --no-copy-ignored",
    "dev": "tsnd -r tsconfig-paths/register --respawn --transpile-only --ignore-watch node_modules src/infra/http/server.ts",
    "start": "node dist/infra/http/server.js",
    "typeorm": "tsnd ./node_modules/typeorm/cli.js"
  },
  "dependencies": {
    "aws-sdk": "^2.843.0",
    "bcryptjs": "^2.4.3",
    "celebrate": "^13.0.4",
    "class-transformer": "^0.3.2",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^8.5.1",
    "mime": "^2.5.0",
    "multer": "^1.4.2",
    "pg": "^8.5.1",
    "reflect-metadata": "^0.1.13",
    "tsyringe": "^4.4.0",
    "typeorm": "^0.2.30",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.16",
    "@babel/core": "^7.12.16",
    "@babel/node": "^7.12.16",
    "@babel/plugin-proposal-class-properties": "^7.12.1",
    "@babel/plugin-proposal-decorators": "^7.12.12",
    "@babel/preset-env": "^7.12.16",
